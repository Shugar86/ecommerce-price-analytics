POSTGRES_USER=courseuser
POSTGRES_PASSWORD=coursepass
POSTGRES_DB=prices_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Получите токен у @BotFather и вставьте сюда:
BOT_TOKEN=your_token_here_from_botfather

# ИИ-воркер: интервал пересчёта (секунды) и демо-история цен для графиков (1/0)
AI_WORKER_INTERVAL_SEC=300
SEED_DEMO_HISTORY=1
# Лимиты и пороги ИИ-цикла (см. app/ai_worker.py, docs/PRODUCT_SCOPE.md)
# AI_MATCH_LIMIT_PER_SHOP=500
# Мин. косинус TF‑IDF для legacy-пары Product EKF↔TDM (кандидаты; по умолчанию 0.45)
# AI_MATCH_MIN_SCORE=0.45
# Основной ревью-контур: fuzzy по normalized_offers (см. app/ai_worker.py)
# AI_MATCH_NORMALIZED_LEFT=EKF YML
# AI_MATCH_NORMALIZED_RIGHT=TDM Electric
# AI_MATCH_OFFER_CAP=400
# Включить старый TF-IDF по таблице products: USE_LEGACY_PRODUCT_MATCHING=1
# KPI: «наш» источник в рыночном слое (имя как в normalized_offers.source_name, не products.source_shop)
# OUR_PRICING_SOURCE=EKF YML
# Загрузка справочника штрихкодов: BARCODE_REFERENCE_CSV=/path/to.csv python -m app.tools.load_barcode_reference
# AI_FORECAST_MIN_POINTS=5

# ETL: макс. товаров с одного крупного фида (0 = без лимита)
# SHOP_ITEM_LIMIT=20000

# Веб-дашборд: если заданы ОБА параметра, страницы и CSV требуют HTTP Basic Auth
# (/health и /ready без пароля)
# WEB_BASIC_AUTH_USER=analyst
# WEB_BASIC_AUTH_PASSWORD=change_me

