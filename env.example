POSTGRES_USER=courseuser
POSTGRES_PASSWORD=coursepass
POSTGRES_DB=prices_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Получите токен у @BotFather и вставьте сюда:
BOT_TOKEN=your_token_here_from_botfather

# ИИ-воркер: интервал пересчёта (секунды) и демо-история цен для графиков (1/0)
AI_WORKER_INTERVAL_SEC=300
SEED_DEMO_HISTORY=1
# Лимиты и пороги ИИ-цикла (см. app/ai_worker.py, docs/PRODUCT_SCOPE.md)
# AI_MATCH_LIMIT_PER_SHOP=500
# Мин. косинус TF‑IDF для legacy-пары Product EKF↔TDM (кандидаты; по умолчанию 0.45)
# AI_MATCH_MIN_SCORE=0.45
# Основной ревью-контур: fuzzy по normalized_offers (см. app/ai_worker.py)
# AI_MATCH_NORMALIZED_LEFT=EKF YML
# AI_MATCH_NORMALIZED_RIGHT=TDM Electric
# AI_MATCH_OFFER_CAP=400
# Fuzzy в match_pair: Jaccard name_only_score; порог (по умолчанию 0.32)
# FUZZY_NAME_JACCARD_MIN=0.32
# Отсев пар без пересечения токенов имени перед match_pair (1 по умолчанию; 0 — все пары)
# AI_MATCH_BLOCK_NO_TOKEN_OVERLAP=1
# Не писать в legacy products для EKF/TDM (источник — normalized_offers); бот/старый /products могут устареть
# SKIP_PRODUCT_UPSERT=0
# Включить старый TF-IDF по таблице products: USE_LEGACY_PRODUCT_MATCHING=1
# KPI: «наш» источник; при пустом OUR_PRICING_SOURCE берётся первый из OUR_PRICING_SOURCE_PRIORITY
# OUR_PRICING_SOURCE=EKF YML
# OUR_PRICING_SOURCE_PRIORITY=WAGO (Комплект-Сервис),Syperopt XLSX,EKF YML
# Несколько пар для fuzzy-ревью: «лево|право;лево2|право2» (имена как в normalized_offers.source_name)
# AI_MATCH_SOURCE_PAIRS=EKF YML|TDM Electric;Syperopt XLSX|WAGO (Комплект-Сервис)
# Загрузка справочника: BARCODE_REFERENCE_CSV=... python -m app.tools.load_barcode_reference
# Скачивание zip Catalog.app: python -m app.tools.fetch_barcode_reference_catalog
# CATALOG_APP_BARCODES_ZIP_URL=https://catalog.app/public-opportunities/download-public-file?fileName=barcodes_csv.zip
# Справочник штрихкодов: при true — один раз при старте collector, если таблица barcode_reference пуста
# BARCODE_REFERENCE_AUTO_LOAD=false
# Tier B: API barcodes-catalog.ru — не в автоматическом pipeline (Cloudflare); только ручной вызов enrich_offers_gaps_from_api
# ENABLE_BARCODES_CATALOG_API=0
# BARCODES_CATALOG_API_MAX_CALLS=40
# BARCODES_CATALOG_API_RPS=0.5
# ETL: Комплект-Сервис (сек: connect, read; для full отдельный read)
# COMPLECT_SERVICE_TIMEOUT_CONNECT=20
# COMPLECT_SERVICE_TIMEOUT_READ=300
# COMPLECT_SERVICE_FULL_TIMEOUT_READ=900
# COMPLECT_SERVICE_MAX_ROWS=0
# Совместимость со старыми именами переменных: COMPLECT_TIMEOUT_CONNECT, COMPLECT_TIMEOUT_READ, COMPLECT_MAX_ROWS
# COMPLECT_TIMEOUT_CONNECT=20
# COMPLECT_TIMEOUT_READ=300
# COMPLECT_MAX_ROWS=0
# ETL: Syperopt / EKF / TDM (сек: connect, read)
# SYPEROPT_TIMEOUT_CONNECT=20
# SYPEROPT_TIMEOUT_READ=900
# SYPEROPT_MAX_ROWS=0
# EKF_TIMEOUT_CONNECT=10
# EKF_TIMEOUT_READ=240
# TDM_TIMEOUT_SEC=120
# Tier C: OWWA (заглушка до настройки API)
# ENABLE_OWWA=0
# OWWA_API_BASE=https://api.owwa.ru/fl_0007/hs/api
# OWWA_API_CLIENT_ID=
# OWWA_API_TOKEN=
# AI_FORECAST_MIN_POINTS=5

# ETL: макс. товаров с одного крупного фида (0 = без лимита). В docker-compose пробрасывается в collector.
# SHOP_ITEM_LIMIT=20000
# FakeStore в collector: ENABLE_FAKESTORE=1

# Веб-дашборд: если заданы ОБА параметра, страницы и CSV требуют HTTP Basic Auth
# (/health и /ready без пароля)
# WEB_BASIC_AUTH_USER=analyst
# WEB_BASIC_AUTH_PASSWORD=change_me

